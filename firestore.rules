rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }

    // Games collection
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Allow host to reset buzzer or typing
        (request.resource.data.firstBuzz == null) ||
        // Only allow setting firstBuzz if it is currently null
        (resource.data.firstBuzz == null && request.resource.data.firstBuzz != null) ||
        // Allow other updates like wrongBuzzes if firstBuzz stays same
        (request.resource.data.firstBuzz == resource.data.firstBuzz)
      );
      
      // Participants subcollection
      match /participants/{participantId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
